---
interface Props {
  compact?: boolean;
}
const { compact = false } = Astro.props;
---

{compact ? (
  <p class="text-xs text-muted-foreground/70">
    <svg class="w-3.5 h-3.5 inline mr-1 text-primary/40" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
    Kai kuriose nuorodose naudojami affiliate partnerių saitai. <a href="/affiliate-atskleidimas/" class="underline hover:text-primary transition-colors duration-200">Sužinokite daugiau</a>.
  </p>
) : (
  <div class="rounded-lg border border-border/50 bg-card p-4 my-8">
    <div class="flex items-start gap-3">
      <div class="w-7 h-7 rounded-md bg-primary/8 flex items-center justify-center shrink-0 mt-0.5">
        <svg class="w-3.5 h-3.5 text-primary" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
      </div>
      <div>
        <p class="font-heading font-semibold text-sm text-foreground mb-1">Skaidrumo pranešimas</p>
        <p class="text-sm text-muted-foreground leading-relaxed">
          antivirusines.lt yra nepriklausomas portalas. Mūsų apžvalgos remiasi objektyviu testavimu. Kai kuriose nuorodose naudojami affiliate partnerių saitai – tai padeda finansuoti svetainę, bet neturi įtakos mūsų vertinimams.
          <a href="/affiliate-atskleidimas/" class="text-primary underline underline-offset-2 hover:text-primary/80 transition-colors duration-200"> Skaityti visą atskleidimą</a>.
        </p>
      </div>
    </div>
  </div>
)}
