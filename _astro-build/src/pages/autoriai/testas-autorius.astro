---
import Base from '../../layouts/Base.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
---

<Base
  title="Testas Autorius"
  description="Testinis autorius CMS patikrinimui."
>
  <div class="container py-8">
    <Breadcrumbs items={[{"label":"Pradžia","path":"/"},{"label":"Testas Autorius","path":"/autoriai/testas-autorius"}]} />

    <div class="mb-10 max-w-2xl">
      <div class="flex items-center gap-4 mb-4">
        <div class="w-16 h-16 rounded-full bg-primary/10 flex items-center justify-center text-primary font-heading font-bold text-xl">
          TA
        </div>
        <div>
          <h1 class="font-heading text-2xl font-bold text-foreground">Testas Autorius</h1>
          
          <div class="flex flex-wrap gap-1.5 mt-1">
            <span class="chip-primary">Testavimas</span>
          </div>
          
        </div>
      </div>
      <p class="text-muted-foreground leading-relaxed">Testinis autorius CMS patikrinimui.</p>
    </div>

    
    <section>
      <h2 class="font-heading text-xl font-bold text-foreground mb-5">Straipsniai</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        
        <a href="/testavimas/cms-testas-publikuotas/" class="group rounded-xl border border-border/50 bg-card p-5 hover:shadow-md hover:border-primary/20 transition-all duration-300">
          <h3 class="font-heading font-bold text-foreground text-sm group-hover:text-primary transition-colors mb-2">CMS testas: publikuotas straipsnis</h3>
          <p class="text-xs text-muted-foreground line-clamp-2 leading-relaxed">Šis straipsnis sukurtas per CMS ir turi būti matomas viešai.</p>
        </a>
        
      </div>
    </section>
    
  </div>
</Base>