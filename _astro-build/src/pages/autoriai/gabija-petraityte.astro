---
import Base from '../../layouts/Base.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
---

<Base
  title="Gabija Petraitytė"
  description="Technologijų žurnalistė ir skaitmeninio raštingumo edukatorė. Rašo apie vaikų saugumą internete, tėvų kontrolės sprendimus ir privatumo apsaugą. Bendradarbiauja su Lietuvos mokyklomis."
>
  <div class="container py-8">
    <Breadcrumbs items={[{"label":"Pradžia","path":"/"},{"label":"Gabija Petraitytė","path":"/autoriai/gabija-petraityte"}]} />

    <div class="mb-10 max-w-2xl">
      <div class="flex items-center gap-4 mb-4">
        <div class="w-16 h-16 rounded-full bg-primary/10 flex items-center justify-center text-primary font-heading font-bold text-xl">
          GP
        </div>
        <div>
          <h1 class="font-heading text-2xl font-bold text-foreground">Gabija Petraitytė</h1>
          
          <div class="flex flex-wrap gap-1.5 mt-1">
            <span class="chip-primary">Tėvų kontrolė</span><span class="chip-primary">Skaitmeninis raštingumas</span><span class="chip-primary">Privatumo apsauga</span>
          </div>
          
        </div>
      </div>
      <p class="text-muted-foreground leading-relaxed">Technologijų žurnalistė ir skaitmeninio raštingumo edukatorė. Rašo apie vaikų saugumą internete, tėvų kontrolės sprendimus ir privatumo apsaugą. Bendradarbiauja su Lietuvos mokyklomis.</p>
    </div>

    
    <section>
      <h2 class="font-heading text-xl font-bold text-foreground mb-5">Straipsniai</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        
        <a href="/tevu-kontrole/vaiko-telefone" class="group rounded-xl border border-border/50 bg-card p-5 hover:shadow-md hover:border-primary/20 transition-all duration-300">
          <h3 class="font-heading font-bold text-foreground text-sm group-hover:text-primary transition-colors mb-2">Tėvų kontrolė vaiko telefone: viskas, ką reikia žinoti</h3>
          <p class="text-xs text-muted-foreground line-clamp-2 leading-relaxed">Kaip nustatyti tėvų kontrolę vaiko telefone? Geriausi sprendimai Android ir iPhone įrenginiams, praktiniai patarimai tėvams.</p>
        </a>
        
        <a href="/saugumo-patarimai/saugus-darbas-kompiuteriu" class="group rounded-xl border border-border/50 bg-card p-5 hover:shadow-md hover:border-primary/20 transition-all duration-300">
          <h3 class="font-heading font-bold text-foreground text-sm group-hover:text-primary transition-colors mb-2">Saugus darbas kompiuteriu: 15 esminių patarimų</h3>
          <p class="text-xs text-muted-foreground line-clamp-2 leading-relaxed">Praktiniai patarimai saugiam darbui kompiuteriu. Nuo slaptažodžių iki atsarginių kopijų – viskas, ką turite žinoti.</p>
        </a>
        
      </div>
    </section>
    
  </div>
</Base>