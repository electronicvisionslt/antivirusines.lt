---
import Base from '../../layouts/Base.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import FAQ from '../../components/FAQ.astro';
import TrustDisclosure from '../../components/TrustDisclosure.astro';
---

<Base
  title="Reklamos virusas telefone 2026 — šalinimo gidas"
  description="Reklamos virusas telefone 2026: kaip pašalinti pop-up reklamas ir adware iš Android telefono. Žingsnis po žingsnio."
  
>
  <div class="container py-8">
    <Breadcrumbs items={[{"label":"Pradžia","path":"/"},{"label":"Virusai","path":"/virusai/"},{"label":"Reklamos virusas telefone","path":"/virusai/reklamos-virusas-telefone/"}]} />

    <div class="mb-10 max-w-2xl">
      <h1 class="font-heading text-3xl md:text-4xl font-bold text-foreground leading-tight mb-3">Reklamos virusas telefone</h1>
      <p class="text-muted-foreground leading-relaxed">Kaip pašalinti reklaminį virusą iš telefono — pop-up reklamos, adware šalinimas.</p>
    </div>

    

    

    
    <TrustDisclosure />
  </div>
