---
import Base from '../../layouts/Base.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import FAQ from '../../components/FAQ.astro';
import TrustDisclosure from '../../components/TrustDisclosure.astro';
---

<Base
  title="Kompiuterinis virusas: kas tai, tipai ir apsauga 2026"
  description="Išsamus gidas apie kompiuterinius virusus — kaip jie veikia, pagrindiniai tipai ir kaip efektyviai apsisaugoti."
  
>
  <article class="container py-8 max-w-4xl" itemScope itemType="https://schema.org/Article">
    <Breadcrumbs items={[{"label":"Pradžia","path":"/"},{"label":"Virusai","path":"/virusai/kompiuterinis-virusas"},{"label":"Kompiuterinis virusas","path":"/virusai/kompiuterinis-virusas"}]} />

    <!-- HERO -->
    <div class="mb-8">
      <h1 class="font-heading text-3xl md:text-4xl lg:text-[2.85rem] font-extrabold text-foreground leading-[1.08] mb-3 tracking-tight" itemProp="headline">
        Kompiuterinis virusas: kas tai ir kaip apsisaugoti
      </h1>
      <p class="text-muted-foreground text-[15px] leading-relaxed max-w-2xl mb-4" itemProp="description">
        Viskas, ką reikia žinoti apie kompiuterinius virusus — tipai, plitimo būdai, atpažinimo požymiai ir efektyviausi apsaugos metodai.
      </p>
      <div class="flex flex-wrap items-center gap-4 text-sm text-muted-foreground/70">
        <span class="font-medium">Matas Jonaitis</span>
        <time itemProp="dateModified" datetime="2026-03-20T16:41:24.649836+00:00">Atnaujinta: 2026-03-20</time>
        <span>· 14 min skaitymo</span>
      </div>
    </div>

    <TrustDisclosure compact />

    <div class="grid grid-cols-1 lg:grid-cols-[1fr_240px] gap-10">
      <div>
        
        <!-- TABLE OF CONTENTS (mobile) -->
        <nav class="rounded-lg border border-border/50 bg-card p-4 my-6 lg:hidden">
          <h4 class="font-heading font-semibold text-xs text-foreground mb-2.5 uppercase tracking-wider">Turinys</h4>
          <ol class="space-y-1.5">
            
            <li>
              <a href="#kas-yra" class="flex items-baseline gap-2 text-sm text-muted-foreground hover:text-primary transition-colors duration-200 group">
                <span class="text-[10px] text-muted-foreground/35 font-mono tabular-nums group-hover:text-primary/50 transition-colors duration-200">01</span>
                Kas yra kompiuterinis virusas?
              </a>
            </li>
            <li>
              <a href="#tipai" class="flex items-baseline gap-2 text-sm text-muted-foreground hover:text-primary transition-colors duration-200 group">
                <span class="text-[10px] text-muted-foreground/35 font-mono tabular-nums group-hover:text-primary/50 transition-colors duration-200">02</span>
                Pagrindiniai virusų tipai
              </a>
            </li>
            <li>
              <a href="#pozymiai" class="flex items-baseline gap-2 text-sm text-muted-foreground hover:text-primary transition-colors duration-200 group">
                <span class="text-[10px] text-muted-foreground/35 font-mono tabular-nums group-hover:text-primary/50 transition-colors duration-200">03</span>
                Kaip atpažinti užkrėstą kompiuterį?
              </a>
            </li>
            <li>
              <a href="#apsauga" class="flex items-baseline gap-2 text-sm text-muted-foreground hover:text-primary transition-colors duration-200 group">
                <span class="text-[10px] text-muted-foreground/35 font-mono tabular-nums group-hover:text-primary/50 transition-colors duration-200">04</span>
                Kaip apsisaugoti nuo virusų?
              </a>
            </li>
          </ol>
        </nav>
        

        <!-- CONTENT SECTIONS -->
        <div class="prose-article">
          
          <section class="mb-8 scroll-mt-20" id="kas-yra">
            <h2 class="font-heading text-xl font-bold text-foreground mb-3">Kas yra kompiuterinis virusas?</h2>
            <p class="text-muted-foreground leading-relaxed">Kompiuterinis virusas yra kenkėjiška programa, kuri gali replikuotis ir plisti iš vieno kompiuterio į kitą. Virusai gali sugadinti failus, pavogti duomenis arba sulėtinti sistemos darbą.</p>
          </section>
          
          <section class="mb-8 scroll-mt-20" id="tipai">
            <h2 class="font-heading text-xl font-bold text-foreground mb-3">Pagrindiniai virusų tipai</h2>
            <p class="text-muted-foreground leading-relaxed">Egzistuoja daugybė skirtingų virusų tipų: failų virusai, makro virusai, boot sektoriaus virusai, trojanai, kirminai ir ransomware. Kiekvienas tipas turi savo plitimo būdą ir poveikį.</p>
          </section>
          
          <section class="mb-8 scroll-mt-20" id="pozymiai">
            <h2 class="font-heading text-xl font-bold text-foreground mb-3">Kaip atpažinti užkrėstą kompiuterį?</h2>
            <p class="text-muted-foreground leading-relaxed">Pagrindiniai požymiai: kompiuteris veikia lėčiau nei įprastai, pasirodo neįprastos klaidos, naršyklė nukreipia į nežinomas svetaines, atsiranda nepažįstamų programų.</p>
          </section>
          
          <section class="mb-8 scroll-mt-20" id="apsauga">
            <h2 class="font-heading text-xl font-bold text-foreground mb-3">Kaip apsisaugoti nuo virusų?</h2>
            <p class="text-muted-foreground leading-relaxed">Naudokite patikimą antivirusinę programą, reguliariai atnaujinkite operacinę sistemą, neatidarinėkite įtartinų el. laiškų priedų ir atsargiai elkitės su nežinomomis nuorodomis.</p>
          </section>
          

          
        </div>

        

        

        <FAQ items={[{"a":"Dauguma virusų negali tiesiogiai sugadinti aparatinės įrangos, tačiau kai kurie gali perkaitinti procesorių ar sugadinti BIOS.","q":"Ar virusas gali sugadinti kompiuterio aparatinę įrangą?"}]} />

        
      </div>

      
      <!-- SIDEBAR TOC (desktop) -->
      <aside class="hidden lg:block">
        <div class="sticky top-20">
          <nav class="rounded-xl border border-border/50 bg-card p-4">
            <h3 class="font-heading font-semibold text-foreground text-sm mb-3">Turinys</h3>
            <ul class="space-y-1.5">
              <li><a href="#kas-yra" class="text-xs text-muted-foreground hover:text-primary transition-colors">Kas yra kompiuterinis virusas?</a></li><li><a href="#tipai" class="text-xs text-muted-foreground hover:text-primary transition-colors">Pagrindiniai virusų tipai</a></li><li><a href="#pozymiai" class="text-xs text-muted-foreground hover:text-primary transition-colors">Kaip atpažinti užkrėstą kompiuterį?</a></li><li><a href="#apsauga" class="text-xs text-muted-foreground hover:text-primary transition-colors">Kaip apsisaugoti nuo virusų?</a></li>
            </ul>
          </nav>
          <div class="mt-5"><TrustDisclosure compact /></div>
        </div>
      </aside>
      
    </div>

    <TrustDisclosure />
  </article>
</Base>