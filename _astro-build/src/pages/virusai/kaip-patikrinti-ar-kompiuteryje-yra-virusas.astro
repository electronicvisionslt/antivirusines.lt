---
import Base from '../../layouts/Base.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import FAQ from '../../components/FAQ.astro';
import TrustDisclosure from '../../components/TrustDisclosure.astro';
---

<Base
  title="Ar kompiuteryje yra virusas? Patikrinimo gidas 2026"
  description="Kaip patikrinti ar kompiuteryje yra virusas 2026? 10 požymių ir žingsnis po žingsnio patikrinimo instrukcija."
  
>
  <div class="container py-8">
    <Breadcrumbs items={[{"label":"Pradžia","path":"/"},{"label":"Virusai","path":"/virusai/"},{"label":"Kaip patikrinti ar kompiuteryje yra virusas","path":"/virusai/kaip-patikrinti-ar-kompiuteryje-yra-virusas/"}]} />

    <div class="mb-10 max-w-2xl">
      <h1 class="font-heading text-3xl md:text-4xl font-bold text-foreground leading-tight mb-3">Kaip patikrinti ar kompiuteryje yra virusas</h1>
      <p class="text-muted-foreground leading-relaxed">Praktinis gidas: simptomai ir patikrinimo būdai kompiuterio virusams aptikti.</p>
    </div>

    

    

    
    <TrustDisclosure />
  </div>
</Base>