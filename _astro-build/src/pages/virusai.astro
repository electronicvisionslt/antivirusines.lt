---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import FAQ from '../components/FAQ.astro';
import TrustDisclosure from '../components/TrustDisclosure.astro';
---

<Base
  title="Virusai ir grėsmės 2026 — kaip atpažinti ir apsisaugoti"
  description="Praktiniai gidai apie kompiuterinius ir mobiliuosius virusus, jų požymius, patikrą, šalinimą ir prevenciją."
  
>
  <div class="container py-8 max-w-4xl mx-auto">
    <Breadcrumbs items={[{"label":"Pradžia","path":"/"},{"label":"Virusai","path":"/virusai/"}]} />

    <!-- HERO -->
    <div class="mb-10">
      <div class="flex items-center gap-2 mb-3">
        <span class="section-label">Slaptažodžių saugumas</span>
        <span class="chip-muted text-[10px]">Atnaujinta 2026</span>
      </div>
      <h1 class="font-heading text-3xl md:text-4xl font-bold text-foreground leading-tight mb-4">
        Virusai ir skaitmeninės grėsmės
      </h1>
      <p class="text-muted-foreground leading-relaxed max-w-2xl">
        Kaip atpažinti pavojingą elgesį, patikrinti įrenginį ir apsaugoti kompiuterį ar telefoną nuo virusų, adware ir kitų grėsmių.
      </p>
    </div>

    

    
    <!-- GUIDES GRID -->
    <div class="mb-5">
      <div class="section-label text-[10px] mb-1.5">Praktiniai gidai</div>
      <h2 class="font-heading text-xl md:text-2xl font-bold text-foreground">Žingsnis po žingsnio instrukcijos</h2>
      <p class="text-sm text-muted-foreground mt-1">Dažniausiai ieškomi slaptažodžių klausimai su aiškiomis instrukcijomis</p>
    </div>
    <div class="grid gap-3 mb-12">
      
      <a href="/virusai/kompiuterinis-virusas/" class="group flex items-start gap-4 p-5 bg-card border border-border/50 rounded-xl hover:border-primary/30 hover:shadow-sm transition-all duration-200">
        <div class="rounded-lg bg-primary/8 p-2.5 shrink-0 group-hover:bg-primary/15 transition-colors">
          <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </div>
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2 mb-1">
            
            
          </div>
          <h3 class="font-heading font-semibold text-foreground group-hover:text-primary transition-colors">Kompiuterinis virusas</h3>
          <p class="text-sm text-muted-foreground mt-1 leading-relaxed">Kas tai, kaip plinta ir ką daryti užsikrėtus.</p>
        </div>
        <span class="mt-3 shrink-0"><svg class="w-4 h-4 text-muted-foreground/30" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg></span>
      </a>
      <a href="/virusai/virusas-telefone/" class="group flex items-start gap-4 p-5 bg-card border border-border/50 rounded-xl hover:border-primary/30 hover:shadow-sm transition-all duration-200">
        <div class="rounded-lg bg-primary/8 p-2.5 shrink-0 group-hover:bg-primary/15 transition-colors">
          <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </div>
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2 mb-1">
            
            
          </div>
          <h3 class="font-heading font-semibold text-foreground group-hover:text-primary transition-colors">Virusas telefone</h3>
          <p class="text-sm text-muted-foreground mt-1 leading-relaxed">Požymiai, šalinimas ir apsauga Android bei iPhone.</p>
        </div>
        <span class="mt-3 shrink-0"><svg class="w-4 h-4 text-muted-foreground/30" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg></span>
      </a>
      <a href="/virusai/kaip-patikrinti-ar-kompiuteryje-yra-virusas/" class="group flex items-start gap-4 p-5 bg-card border border-border/50 rounded-xl hover:border-primary/30 hover:shadow-sm transition-all duration-200">
        <div class="rounded-lg bg-primary/8 p-2.5 shrink-0 group-hover:bg-primary/15 transition-colors">
          <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </div>
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2 mb-1">
            
            
          </div>
          <h3 class="font-heading font-semibold text-foreground group-hover:text-primary transition-colors">Kaip patikrinti kompiuterį</h3>
          <p class="text-sm text-muted-foreground mt-1 leading-relaxed">Pilnas skenavimas ir infekcijos požymių patikra.</p>
        </div>
        <span class="mt-3 shrink-0"><svg class="w-4 h-4 text-muted-foreground/30" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg></span>
      </a>
      <a href="/virusai/reklamos-virusas-telefone/" class="group flex items-start gap-4 p-5 bg-card border border-border/50 rounded-xl hover:border-primary/30 hover:shadow-sm transition-all duration-200">
        <div class="rounded-lg bg-primary/8 p-2.5 shrink-0 group-hover:bg-primary/15 transition-colors">
          <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </div>
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2 mb-1">
            
            
          </div>
          <h3 class="font-heading font-semibold text-foreground group-hover:text-primary transition-colors">Reklamos virusas telefone</h3>
          <p class="text-sm text-muted-foreground mt-1 leading-relaxed">Kaip pašalinti adware ir sustabdyti iššokančias reklamas.</p>
        </div>
        <span class="mt-3 shrink-0"><svg class="w-4 h-4 text-muted-foreground/30" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg></span>
      </a>
    </div>
    

    

    

    

    

    

    <TrustDisclosure />
  </div>
</Base>