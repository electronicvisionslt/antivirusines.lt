>
  <div class="container py-8 max-w-5xl mx-auto">
    <Breadcrumbs items={[{"label":"Pradžia","path":"/"},{"label":"Tėvų kontrolė","path":"/tevu-kontrole/"}]} />

    <!-- ═══ 1. HERO ═══ -->
