    </div>
          <div class="min-w-0">
            <span class="chip-primary mb-1">Geriausia 2026</span>
            <span class="text-sm text-foreground font-semibold block leading-tight">Qustodio</span>
            <span class="text-[11px] text-muted-foreground">Nuo 3.58 €/mėn.</span>
          </div>
        </div>
        
