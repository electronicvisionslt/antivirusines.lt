---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import FAQ from '../components/FAQ.astro';
import TrustDisclosure from '../components/TrustDisclosure.astro';
---

<Base
  title="Slaptažodžių saugumas 2026 — patarimai ir gidai"
  description="Viskas apie slaptažodžių saugumą: kaip sukurti stiprų slaptažodį, kur jį saugoti, kaip pakeisti ir ką daryti pamiršus."
  
>
  <div class="container py-8 max-w-4xl mx-auto">
    <Breadcrumbs items={[{"label":"Pradžia","path":"/"},{"label":"Slaptažodžių saugumas","path":"/slaptazodziu-saugumas"}]} />

    <!-- HERO -->
    <div class="mb-10">
      <div class="flex items-center gap-2 mb-3">
        <span class="section-label">Slaptažodžių saugumas</span>
        <span class="chip-muted text-[10px]">Atnaujinta 2026</span>
      </div>
      <h1 class="font-heading text-3xl md:text-4xl font-bold text-foreground leading-tight mb-4">
        Slaptažodžių saugumas: kaip apsaugoti savo paskyras
      </h1>
      <p class="text-muted-foreground leading-relaxed max-w-2xl">
        Stiprus slaptažodis — pirmoji gynybos linija nuo kibernetinių grėsmių. Šiame hub'e rasite praktinius gidus, kaip kurti, keisti ir saugoti slaptažodžius pagal naujausias 2026 m. NIST rekomendacijas.
      </p>
    </div>

    
    <!-- STATS BAR -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-10">
      
      <div class="bg-card border border-border/50 rounded-xl p-4 text-center">
        <div class="w-5 h-5 text-primary mx-auto mb-2"><svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/></svg></div>
        <div class="font-heading text-xl font-bold text-foreground">85,6%</div>
        <div class="text-xs text-muted-foreground leading-snug mt-1">Įprastų slaptažodžių AI nulaužia per <10 sek.</div>
      </div>
      <div class="bg-card border border-border/50 rounded-xl p-4 text-center">
        <div class="w-5 h-5 text-primary mx-auto mb-2"><svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/></svg></div>
        <div class="font-heading text-xl font-bold text-foreground">15+</div>
        <div class="text-xs text-muted-foreground leading-snug mt-1">Simbolių — NIST 2026 rekomenduojamas minimumas</div>
      </div>
      <div class="bg-card border border-border/50 rounded-xl p-4 text-center">
        <div class="w-5 h-5 text-primary mx-auto mb-2"><svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/></svg></div>
        <div class="font-heading text-xl font-bold text-foreground">70%</div>
        <div class="text-xs text-muted-foreground leading-snug mt-1">Žmonių naudoja tuos pačius slaptažodžius</div>
      </div>
      <div class="bg-card border border-border/50 rounded-xl p-4 text-center">
        <div class="w-5 h-5 text-primary mx-auto mb-2"><svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/></svg></div>
        <div class="font-heading text-xl font-bold text-foreground">2FA</div>
        <div class="text-xs text-muted-foreground leading-snug mt-1">Sumažina paskyros perėmimo riziką 99%</div>
      </div>
    </div>
    

    
    <!-- GUIDES GRID -->
    <div class="mb-5">
      <div class="section-label text-[10px] mb-1.5">Praktiniai gidai</div>
      <h2 class="font-heading text-xl md:text-2xl font-bold text-foreground">Žingsnis po žingsnio instrukcijos</h2>
      <p class="text-sm text-muted-foreground mt-1">Dažniausiai ieškomi slaptažodžių klausimai su aiškiomis instrukcijomis</p>
    </div>
    <div class="grid gap-3 mb-12">
      
      <a href="/slaptazodziu-saugumas/slaptazodziu-tvarkykles" class="group flex items-start gap-4 p-5 bg-card border border-border/50 rounded-xl hover:border-primary/30 hover:shadow-sm transition-all duration-200">
        <div class="rounded-lg bg-primary/8 p-2.5 shrink-0 group-hover:bg-primary/15 transition-colors">
          <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </div>
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2 mb-1">
            <span class="chip-muted text-[10px]">Palyginimas</span>
            <span class="text-[10px] text-muted-foreground flex items-center gap-0.5">8 min</span>
          </div>
          <h3 class="font-heading font-semibold text-foreground group-hover:text-primary transition-colors">Geriausios slaptažodžių tvarkyklės 2026</h3>
          <p class="text-sm text-muted-foreground mt-1 leading-relaxed">Nepriklausomas palyginimas: 1Password, Bitwarden, NordPass, RoboForm ir Proton Pass — kuri geriausia jums?</p>
        </div>
        <span class="mt-3 shrink-0"><svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg></span>
      </a>
      <a href="/slaptazodziu-saugumas/kaip-pakeisti-gmail-slaptazodi" class="group flex items-start gap-4 p-5 bg-card border border-border/50 rounded-xl hover:border-primary/30 hover:shadow-sm transition-all duration-200">
        <div class="rounded-lg bg-primary/8 p-2.5 shrink-0 group-hover:bg-primary/15 transition-colors">
          <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </div>
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2 mb-1">
            <span class="chip-muted text-[10px]">How-to</span>
            <span class="text-[10px] text-muted-foreground flex items-center gap-0.5">4 min</span>
          </div>
          <h3 class="font-heading font-semibold text-foreground group-hover:text-primary transition-colors">Kaip pakeisti Gmail slaptažodį</h3>
          <p class="text-sm text-muted-foreground mt-1 leading-relaxed">Žingsnis po žingsnio instrukcija kompiuteryje ir telefone. Taip pat — kaip įjungti dviejų veiksnių autentifikaciją.</p>
        </div>
        <span class="mt-3 shrink-0"><svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg></span>
      </a>
      <a href="/slaptazodziu-saugumas/kaip-pakeisti-wifi-slaptazodi" class="group flex items-start gap-4 p-5 bg-card border border-border/50 rounded-xl hover:border-primary/30 hover:shadow-sm transition-all duration-200">
        <div class="rounded-lg bg-primary/8 p-2.5 shrink-0 group-hover:bg-primary/15 transition-colors">
          <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </div>
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2 mb-1">
            <span class="chip-muted text-[10px]">How-to</span>
            <span class="text-[10px] text-muted-foreground flex items-center gap-0.5">5 min</span>
          </div>
          <h3 class="font-heading font-semibold text-foreground group-hover:text-primary transition-colors">Kaip pakeisti WiFi slaptažodį</h3>
          <p class="text-sm text-muted-foreground mt-1 leading-relaxed">Instrukcija populiariausiems routeriams: TP-Link, Huawei, Asus, Telia ir kitiems. Su nuotraukomis.</p>
        </div>
        <span class="mt-3 shrink-0"><svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg></span>
      </a>
      <a href="/slaptazodziu-saugumas/ka-daryti-pamirsus-slaptazodi" class="group flex items-start gap-4 p-5 bg-card border border-border/50 rounded-xl hover:border-primary/30 hover:shadow-sm transition-all duration-200">
        <div class="rounded-lg bg-primary/8 p-2.5 shrink-0 group-hover:bg-primary/15 transition-colors">
          <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </div>
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2 mb-1">
            <span class="chip-muted text-[10px]">Gidas</span>
            <span class="text-[10px] text-muted-foreground flex items-center gap-0.5">6 min</span>
          </div>
          <h3 class="font-heading font-semibold text-foreground group-hover:text-primary transition-colors">Ką daryti pamiršus slaptažodį</h3>
          <p class="text-sm text-muted-foreground mt-1 leading-relaxed">Kaip atkurti prieigą prie Gmail, Facebook, Instagram ir kitų paskyrų. Prevencijos patarimai ateičiai.</p>
        </div>
        <span class="mt-3 shrink-0"><svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg></span>
      </a>
    </div>
    

    
    <!-- PASSWORD STRENGTH TABLE -->
    <div class="mb-5">
      <div class="section-label text-[10px] mb-1.5">Ar jūsų slaptažodis saugus?</div>
      <h2 class="font-heading text-xl md:text-2xl font-bold text-foreground">Slaptažodžio stiprumo pavyzdžiai</h2>
    </div>
    <div class="bg-card border border-border/50 rounded-xl overflow-hidden mb-12">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-border/50 bg-muted/30">
              <th class="text-left font-medium text-muted-foreground p-3">Slaptažodis</th>
              <th class="text-left font-medium text-muted-foreground p-3">Stiprumas</th>
              <th class="text-left font-medium text-muted-foreground p-3">Nulaužimo laikas</th>
            </tr>
          </thead>
          <tbody>
            
            <tr class="border-b border-border/30 last:border-0">
              <td class="p-3 font-mono text-xs">slaptazodis123</td>
              <td class="p-3"><span class="inline-flex px-2 py-0.5 rounded-md text-xs font-medium bg-destructive/10 text-destructive">Labai silpnas</span></td>
              <td class="p-3 text-muted-foreground">< 1 sekundė</td>
            </tr>
            <tr class="border-b border-border/30 last:border-0">
              <td class="p-3 font-mono text-xs">Katinas2024!</td>
              <td class="p-3"><span class="inline-flex px-2 py-0.5 rounded-md text-xs font-medium bg-orange-50 text-orange-600">Silpnas</span></td>
              <td class="p-3 text-muted-foreground">~3 valandos</td>
            </tr>
            <tr class="border-b border-border/30 last:border-0">
              <td class="p-3 font-mono text-xs">K!m9#xLp2$vR</td>
              <td class="p-3"><span class="inline-flex px-2 py-0.5 rounded-md text-xs font-medium bg-amber-50 text-amber-600">Vidutinis</span></td>
              <td class="p-3 text-muted-foreground">~400 metų</td>
            </tr>
            <tr class="border-b border-border/30 last:border-0">
              <td class="p-3 font-mono text-xs">zuvis-kelias-menas-7!Rx</td>
              <td class="p-3"><span class="inline-flex px-2 py-0.5 rounded-md text-xs font-medium bg-success/10 text-success">Stiprus</span></td>
              <td class="p-3 text-muted-foreground">> 1 mlrd. metų</td>
            </tr>
          </tbody>
        </table>
      </div>
      <div class="px-4 py-3 bg-muted/20 border-t border-border/30">
        <p class="text-xs text-muted-foreground">* Nulaužimo laikai paremti 2025–2026 m. GPU benchmarkais. Stiprūs passphrase tipo slaptažodžiai yra itin sunkiai nulaužiami.</p>
      </div>
    </div>
    

    
    <!-- DO'S & DON'TS -->
    <div class="mb-5">
      <div class="section-label text-[10px] mb-1.5">NIST 2026 gairės</div>
      <h2 class="font-heading text-xl md:text-2xl font-bold text-foreground">Ką daryti ir ko nedaryti</h2>
    </div>
    <div class="grid md:grid-cols-2 gap-3 mb-12">
      <div class="bg-card border border-success/20 rounded-xl p-5">
        <h3 class="font-heading font-semibold text-success flex items-center gap-2 mb-3">
          <svg class="w-3 h-3 text-success mt-0.5 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg> Taip — darykite
        </h3>
        <ul class="space-y-2.5">
          
          <li class="flex items-start gap-2 text-sm text-foreground">
            <svg class="w-3 h-3 text-success mt-0.5 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <span>Naudokite bent 15 simbolių (NIST 2026 rekomendacija)</span>
          </li>
          <li class="flex items-start gap-2 text-sm text-foreground">
            <svg class="w-3 h-3 text-success mt-0.5 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <span>Naudokite slaptažodžių tvarkyklę</span>
          </li>
          <li class="flex items-start gap-2 text-sm text-foreground">
            <svg class="w-3 h-3 text-success mt-0.5 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <span>Įjunkite dviejų veiksnių autentifikaciją (2FA)</span>
          </li>
          <li class="flex items-start gap-2 text-sm text-foreground">
            <svg class="w-3 h-3 text-success mt-0.5 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <span>Naudokite passphrase — 3–5 atsitiktinių žodžių</span>
          </li>
          <li class="flex items-start gap-2 text-sm text-foreground">
            <svg class="w-3 h-3 text-success mt-0.5 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <span>Tikrinkite ar slaptažodis nebuvo nutekėjęs (haveibeenpwned.com)</span>
          </li>
        </ul>
      </div>
      <div class="bg-card border border-destructive/20 rounded-xl p-5">
        <h3 class="font-heading font-semibold text-destructive flex items-center gap-2 mb-3">
          <svg class="w-3 h-3 text-muted-foreground/30 mt-0.5 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg> Ne — venkite
        </h3>
        <ul class="space-y-2.5">
          
          <li class="flex items-start gap-2 text-sm text-foreground">
            <svg class="w-3 h-3 text-muted-foreground/30 mt-0.5 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
            <span>Nenaudokite vardo, gimimo datos ar „123456&quot;</span>
          </li>
          <li class="flex items-start gap-2 text-sm text-foreground">
            <svg class="w-3 h-3 text-muted-foreground/30 mt-0.5 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
            <span>Nesaugokite slaptažodžių naršyklėje be master password</span>
          </li>
          <li class="flex items-start gap-2 text-sm text-foreground">
            <svg class="w-3 h-3 text-muted-foreground/30 mt-0.5 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
            <span>Nenaudokite to paties slaptažodžio keliose paskyrose</span>
          </li>
          <li class="flex items-start gap-2 text-sm text-foreground">
            <svg class="w-3 h-3 text-muted-foreground/30 mt-0.5 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
            <span>Nekeiskite slaptažodžio reguliariai be priežasties</span>
          </li>
          <li class="flex items-start gap-2 text-sm text-foreground">
            <svg class="w-3 h-3 text-muted-foreground/30 mt-0.5 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
            <span>Nesiųskite slaptažodžių el. paštu ar žinutėmis</span>
          </li>
        </ul>
      </div>
    </div>
    

    
    <!-- RECOMMENDED TOOLS -->
    <div class="mb-5">
      <div class="section-label text-[10px] mb-1.5">Rekomenduojami įrankiai</div>
      <h2 class="font-heading text-xl md:text-2xl font-bold text-foreground">Slaptažodžių tvarkyklės</h2>
    </div>
    <div class="grid sm:grid-cols-3 gap-3 mb-12">
      
      <div class="bg-card border border-border/50 rounded-xl p-5">
        <div class="flex items-center justify-between mb-2">
          <h3 class="font-heading font-semibold text-foreground">Bitwarden</h3>
          <span class="chip-muted text-[10px]">Nemokama</span>
        </div>
        <p class="text-sm text-muted-foreground leading-relaxed mb-3">Geriausia nemokama tvarkyklė. Atviro kodo, audituota, veikia visose platformose.</p>
        <a href="https://bitwarden.com" target="_blank" rel="noopener noreferrer"
          class="text-xs font-medium text-primary hover:text-primary/80 inline-flex items-center gap-1 transition-colors">
          Sužinoti daugiau <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
      <div class="bg-card border border-border/50 rounded-xl p-5">
        <div class="flex items-center justify-between mb-2">
          <h3 class="font-heading font-semibold text-foreground">1Password</h3>
          <span class="chip-muted text-[10px]">Nuo 2,99 $/mėn.</span>
