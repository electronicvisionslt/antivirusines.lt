---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import FAQ from '../components/FAQ.astro';
import TrustDisclosure from '../components/TrustDisclosure.astro';
---

<Base
  title="Testavimo kategorija"
  description="Kategorija CMS testavimui."
  
>
  <div class="container py-8">
    <Breadcrumbs items={[{"label":"Pradžia","path":"/"},{"label":"Testavimo kategorija","path":"/testavimas"}]} />

    <div class="mb-10 max-w-2xl">
      <h1 class="font-heading text-3xl md:text-4xl font-bold text-foreground leading-tight mb-3">Testavimo kategorija</h1>
      <p class="text-muted-foreground leading-relaxed">Kategorija CMS testavimui.</p>
    </div>

    

    
    <section class="mb-12">
      <h2 class="font-heading text-xl font-bold text-foreground mb-5">Straipsniai ir gidai</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        
        <a href="/testavimas/cms-testas-publikuotas" class="group rounded-xl border border-border/50 bg-card p-5 hover:shadow-md hover:border-primary/20 transition-all duration-300">
          <h3 class="font-heading font-bold text-foreground text-sm group-hover:text-primary transition-colors mb-2">CMS testas: publikuotas straipsnis</h3>
          <p class="text-xs text-muted-foreground line-clamp-2 leading-relaxed">Šis straipsnis sukurtas per CMS ir turi būti matomas viešai.</p>
          <div class="flex items-center gap-2 mt-3 text-[11px] text-muted-foreground/60">
            <time>2026-03-20</time>
            <span>· 5 min</span>
          </div>
        </a>
        
      </div>
    </section>
    

    
    <TrustDisclosure />
  </div>
</Base>