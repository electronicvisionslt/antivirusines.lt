---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import FAQ from '../components/FAQ.astro';
import TrustDisclosure from '../components/TrustDisclosure.astro';
---

<Base
  title="Antivirusinės programos"
  description="Išsamūs antivirusinių programų palyginimai, apžvalgos ir rekomendacijos. Padedame išsirinkti geriausią apsaugą jūsų kompiuteriui ar telefonui."
  
>
  <div class="container py-8">
    <Breadcrumbs items={[{"label":"Pradžia","path":"/"},{"label":"Antivirusinės programos","path":"/antivirusines-programos/"}]} />

    <div class="mb-10 max-w-2xl">
      <h1 class="font-heading text-3xl md:text-4xl font-bold text-foreground leading-tight mb-3">Antivirusinės programos</h1>
      <p class="text-muted-foreground leading-relaxed">Išsamūs antivirusinių programų palyginimai, apžvalgos ir rekomendacijos. Padedame išsirinkti geriausią apsaugą jūsų kompiuteriui ar telefonui.</p>
    </div>

    
    <section class="mb-12">
      <h2 class="font-heading text-xl font-bold text-foreground mb-5">Temos šiame skyriuje</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        
        <a href="/antivirusines-programos/nemokamos/" class="group rounded-xl border border-border/50 bg-card p-5 hover:shadow-md hover:border-primary/20 transition-all duration-300">
          <h3 class="font-heading font-bold text-foreground text-sm group-hover:text-primary transition-colors mb-2">Nemokamos antivirusinės programos</h3>
          <p class="text-xs text-muted-foreground line-clamp-3 leading-relaxed">Geriausi nemokami antivirusiniai sprendimai 2026 metams. Palyginome populiariausias nemokamas antivirusines programas pagal apsaugos efektyvumą, papildomas funkcijas ir sistemos poveikį.</p>
          <span class="inline-flex items-center gap-1.5 mt-3 text-[11px] font-heading font-semibold text-primary">Atverti temą <svg class="w-4 h-4 text-muted-foreground/30" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg></span>
        </a>
        
        <a href="/antivirusines-programos/telefonui/" class="group rounded-xl border border-border/50 bg-card p-5 hover:shadow-md hover:border-primary/20 transition-all duration-300">
          <h3 class="font-heading font-bold text-foreground text-sm group-hover:text-primary transition-colors mb-2">Antivirusinė telefonui</h3>
          <p class="text-xs text-muted-foreground line-clamp-3 leading-relaxed">Geriausios antivirusinės programos Android ir iOS telefonams 2026 metais. Nepriklausomas Top 5 palyginimas su detaliais vertinimais.</p>
          <span class="inline-flex items-center gap-1.5 mt-3 text-[11px] font-heading font-semibold text-primary">Atverti temą <svg class="w-4 h-4 text-muted-foreground/30" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg></span>
        </a>
        
        <a href="/antivirusines-programos/kompiuteriui/" class="group rounded-xl border border-border/50 bg-card p-5 hover:shadow-md hover:border-primary/20 transition-all duration-300">
          <h3 class="font-heading font-bold text-foreground text-sm group-hover:text-primary transition-colors mb-2">Antivirusinė kompiuteriui</h3>
          <p class="text-xs text-muted-foreground line-clamp-3 leading-relaxed">Geriausių antivirusinių programų palyginimas Windows ir Mac kompiuteriams. Nepriklausomos apžvalgos ir rekomendacijos.</p>
          <span class="inline-flex items-center gap-1.5 mt-3 text-[11px] font-heading font-semibold text-primary">Atverti temą <svg class="w-4 h-4 text-muted-foreground/30" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg></span>
        </a>
        
      </div>
    </section>
    

    
    <section class="mb-12">
      <h2 class="font-heading text-xl font-bold text-foreground mb-5">Straipsniai ir gidai</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        
        <a href="/antivirusines-programos/nemokamos/" class="group rounded-xl border border-border/50 bg-card p-5 hover:shadow-md hover:border-primary/20 transition-all duration-300">
          <h3 class="font-heading font-bold text-foreground text-sm group-hover:text-primary transition-colors mb-2">Geriausios nemokamos antivirusinės programos 2025 m.</h3>
          <p class="text-xs text-muted-foreground line-clamp-2 leading-relaxed">Išsami nemokamų antivirusinių programų apžvalga. Palyginkite funkcijas, apsaugos lygį ir pasirinkite geriausią nemokamą antivirusinę.</p>
          <div class="flex items-center gap-2 mt-3 text-[11px] text-muted-foreground/60">
            <time>2026-03-20</time>
            <span>· 12 min</span>
          </div>
        </a>
        
        <a href="/antivirusines-programos/telefonui/" class="group rounded-xl border border-border/50 bg-card p-5 hover:shadow-md hover:border-primary/20 transition-all duration-300">
          <h3 class="font-heading font-bold text-foreground text-sm group-hover:text-primary transition-colors mb-2">Geriausios antivirusinės programos telefonui 2025 m.</h3>
          <p class="text-xs text-muted-foreground line-clamp-2 leading-relaxed">Apsaugokite savo telefoną nuo virusų ir kenkėjiškų programų. Apžvelgiame geriausias antivirusines programas Android ir iOS įrenginiams.</p>
          <div class="flex items-center gap-2 mt-3 text-[11px] text-muted-foreground/60">
            <time>2026-03-20</time>
            <span>· 10 min</span>
          </div>
        </a>
        
        <a href="/antivirusines-programos/kompiuteriui/" class="group rounded-xl border border-border/50 bg-card p-5 hover:shadow-md hover:border-primary/20 transition-all duration-300">
          <h3 class="font-heading font-bold text-foreground text-sm group-hover:text-primary transition-colors mb-2">Geriausios antivirusinės programos kompiuteriui 2025 m.</h3>
          <p class="text-xs text-muted-foreground line-clamp-2 leading-relaxed">Išsami antivirusinių programų kompiuteriui apžvalga. Windows ir Mac apsaugos sprendimai – nuo nemokamų iki premium variantų.</p>
          <div class="flex items-center gap-2 mt-3 text-[11px] text-muted-foreground/60">
            <time>2026-03-20</time>
            <span>· 15 min</span>
          </div>
        </a>
        
      </div>
    </section>
    

    <FAQ items={[{"a":"Taip, antivirusinė programa yra vienas svarbiausių įrankių apsaugoti jūsų įrenginį nuo kenkėjiškos programinės įrangos, virusų ir kitų grėsmių.","q":"Ar būtina naudoti antivirusinę programą?"},{"a":"Nemokamos antivirusinės suteikia bazinę apsaugą, tačiau mokamos versijos paprastai siūlo pažangesnę apsaugą, VPN, slaptažodžių tvarkyklę ir techninę pagalbą.","q":"Kuo skiriasi nemokamos ir mokamos antivirusinės?"},{"a":"Rekomenduojama įjungti automatinius atnaujinimus, kad antivirusinė visada turėtų naujausias virusų duomenų bazes.","q":"Kaip dažnai reikia atnaujinti antivirusinę?"}]} />
    <TrustDisclosure />
  </div>
</Base>