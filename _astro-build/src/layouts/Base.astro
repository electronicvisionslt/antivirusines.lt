---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  canonicalUrl?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  noindex?: boolean;
  jsonLd?: Record<string, unknown>;
}

const {
  title,
  description,
  canonicalUrl,
  ogTitle,
  ogDescription,
  ogImage,
  noindex = false,
  jsonLd,
} = Astro.props;

const siteName = 'antivirusines.lt';
const fullTitle = title.includes(siteName) ? title : `${title} | ${siteName}`;

// Auto-generate canonical from current URL if not explicitly provided
const siteUrl = 'https://antivirusines.lt';
let canonical = canonicalUrl;
if (!canonical) {
  const path = Astro.url.pathname.replace(/\/?$/, '/');
  canonical = `${siteUrl}${path}`;
}
// Always ensure trailing slash on canonical
if (canonical && !canonical.endsWith('/')) {
  canonical = canonical + '/';
}
// Default JSON-LD: WebSite schema for every page
const defaultJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: siteName,
  url: siteUrl,
  inLanguage: 'lt',
  description: description || 'Nepriklausomos antivirusinių programų apžvalgos, saugumo gidai ir patarimai lietuvių kalba.',
};

const structuredData = jsonLd || defaultJsonLd;
---
<!DOCTYPE html>
<html lang="lt">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/png" href="/favicon.png" />
  <title>{fullTitle}</title>
  {description && <meta name="description" content={description} />}
  <link rel="canonical" href={canonical} />
  {noindex && <meta name="robots" content="noindex, nofollow" />}

  <!-- Hreflang — single-language site, self-referencing -->
  <link rel="alternate" hreflang="lt" href={canonical} />
  <link rel="alternate" hreflang="x-default" href={canonical} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={ogTitle || title} />
  {(ogDescription || description) && <meta property="og:description" content={ogDescription || description} />}
  {ogImage && <meta property="og:image" content={ogImage} />}
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content={siteName} />
  <meta property="og:locale" content="lt_LT" />

  <!-- JSON-LD Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Outfit:wght@600;700;800&display=swap" rel="stylesheet" />
</head>
<body class="flex flex-col min-h-screen bg-background text-foreground font-sans">
  <Header />
  <main class="flex-1">
    <slot />
  </main>
  <Footer />
</body>
</html>
