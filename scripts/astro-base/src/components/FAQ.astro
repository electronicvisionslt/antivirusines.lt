---
interface Props {
  items: { q: string; a: string }[];
}
const { items } = Astro.props;
---

{items.length > 0 && (
  <section class="my-10" itemScope itemType="https://schema.org/FAQPage">
    <h2 class="font-heading text-xl font-bold text-foreground mb-5">Dažnai užduodami klausimai</h2>
    <div class="space-y-2">
      {items.map(item => (
        <details class="group rounded-xl border border-border/50 bg-card" itemScope itemProp="mainEntity" itemType="https://schema.org/Question">
          <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none text-sm font-heading font-semibold text-foreground hover:text-primary transition-colors">
            <span itemProp="name">{item.q}</span>
            <svg class="w-4 h-4 text-muted-foreground shrink-0 transition-transform duration-200 group-open:rotate-180" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
          </summary>
          <div class="px-5 pb-4 text-sm text-muted-foreground leading-relaxed" itemScope itemProp="acceptedAnswer" itemType="https://schema.org/Answer">
            <p itemProp="text">{item.a}</p>
          </div>
        </details>
      ))}
    </div>
  </section>
)}
