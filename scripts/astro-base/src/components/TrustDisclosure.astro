---
interface Props {
  compact?: boolean;
}
const { compact = false } = Astro.props;
---

<aside class={`rounded-xl border border-border/50 bg-muted/30 ${compact ? 'p-3' : 'p-5'}`}>
  <div class="flex items-start gap-3">
    <svg class={`${compact ? 'w-4 h-4' : 'w-5 h-5'} text-primary shrink-0 mt-0.5`} xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/></svg>
    <div>
      <p class={`font-heading font-semibold text-foreground ${compact ? 'text-xs mb-1' : 'text-sm mb-1.5'}`}>Skaidrumas ir pasitikėjimas</p>
      <p class={`text-muted-foreground leading-relaxed ${compact ? 'text-[11px]' : 'text-xs'}`}>
        Kai kurios nuorodos šiame puslapyje yra affiliate partnerių nuorodos. Tai reiškia, kad galime gauti komisinį mokestį, jei nuspręsite įsigyti produktą per mūsų nuorodą — jums tai nekainuoja papildomai. Mūsų apžvalgos ir rekomendacijos yra nepriklausomos ir pagrįstos objektyviais kriterijais.
      </p>
    </div>
  </div>
</aside>
